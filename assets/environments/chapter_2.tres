[gd_resource type="Environment" load_steps=3 format=3]

[ext_resource type="CompressedTexture2D" uid="uid://bqypifr56pb71" path="res://assets/hdri/ch2_sky.hdr" id="1_ch2sky"]

[sub_resource type="PanoramaSkyMaterial" id="PanoramaSkyMaterial_ch2"]
panorama = ExtResource("1_ch2sky")

[sub_resource type="Sky" id="Sky_ch2"]
sky_material = SubResource("PanoramaSkyMaterial_ch2")

[resource]
; ============================================================
; Chapter 2: Training Grounds — WorldEnvironment
; "A cool neural void where baby models learn to crawl.
;  The blue-green glow is just gradient descent visualized."
; Extends base_env values with cool blue-green neural theming.
; ============================================================

; --- Sky (neutral studio HDRI, brighter than Ch1 — training needs visibility) ---
background_mode = 2
sky = SubResource("Sky_ch2")
sky_custom_fov = 0.0
background_energy_multiplier = 0.5

; --- Ambient light — cool blue-green haze from all those loss functions converging ---
ambient_light_source = 1
ambient_light_color = Color(0.04, 0.08, 0.07, 1)
ambient_light_energy = 0.4

; --- Tonemap (FILMIC = 3) ---
tonemap_mode = 3
tonemap_exposure = 1.0

; --- Glow (bloom) — tinted toward blue-green for neural network aesthetics ---
glow_enabled = true
glow_intensity = 0.7
glow_strength = 1.0
glow_bloom = 0.5
glow_hdr_threshold = 0.9
glow_blend_mode = 0

; --- SSAO (slightly softer than Ch1 — cleaner environment) ---
ssao_enabled = true
ssao_radius = 1.5
ssao_intensity = 1.8

; --- SSIL ---
ssil_enabled = true
ssil_radius = 5.0
ssil_intensity = 1.0

; --- SDFGI ---
sdfgi_enabled = true
sdfgi_use_occlusion = true

; --- Fog — cool blue-green, the color of a thousand training epochs ---
fog_enabled = true
fog_light_color = Color(0.3, 0.7, 0.6, 1)
fog_density = 0.012

; --- Volumetric Fog (lighter than Ch1 — this place is organized, not rotting) ---
volumetric_fog_enabled = true
volumetric_fog_density = 0.02
volumetric_fog_albedo = Color(0.03, 0.07, 0.06, 1)
volumetric_fog_emission = Color(0.02, 0.05, 0.04, 1)

; --- Post-processing — slightly cooler and more saturated than base ---
adjustment_enabled = true
adjustment_contrast = 1.05
adjustment_saturation = 1.1
